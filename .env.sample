# Copy/adjust as needed. Vite only exposes VITE_-prefixed vars.
#
# Flavour is chosen by Vite --mode (see package.json scripts):
#   local (default) -> in-app mock, no backend          (npm run dev)
#   dev | stage | prod -> real backend at VITE_API_BASE_URL
#
# Committed .env.dev / .env.stage / .env.prod set the mode + base URL for those builds,
# so you normally don't edit this file — it documents every var.

VITE_DATA_MODE=local
VITE_API_BASE_URL=https://api.interiorbazzar.com
VITE_API_LATENCY=200

# Optional explicit override of the mock toggle (else derived from VITE_DATA_MODE,
# i.e. local -> mock on, dev/stage/prod -> mock off). Useful to run local UI vs a real API:
# VITE_USE_MOCK_API=false
